{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob|Agent|WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/tracker.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
